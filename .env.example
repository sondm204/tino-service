PORT=4000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_TOKEN_SECRET=change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
TELEGRAM_BOT_SERVICE_SECRET=replace-with-a-long-random-secret
RESEND_API_KEY=
EMAIL_FROM=Tino Expense <noreply@example.com>

# Firebase Cloud Messaging. Use one of these credential options.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# S3-compatible object storage. For MinIO, set endpoint and force path style.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tino
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/tino
